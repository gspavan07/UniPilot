{
    "name": "unipilot-backend",
    "version": "1.0.0",
    "description": "UniPilot - Multi-tenant University Management System Backend",
    "main": "server.js",
    "type": "module",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "test": "jest --coverage",
        "test:watch": "jest --watch",
        "test:integration": "jest --testPathPattern=tests/integration",
        "migrate": "node -r dotenv/config node_modules/.bin/sequelize-cli db:migrate",
        "migrate:undo": "node -r dotenv/config node_modules/.bin/sequelize-cli db:migrate:undo",
        "seed": "node -r dotenv/config node_modules/.bin/sequelize-cli db:seed:all",
        "seed:undo": "node -r dotenv/config node_modules/.bin/sequelize-cli db:seed:undo",
        "lint": "eslint src --ext .js",
        "lint:fix": "eslint src --ext .js --fix",
        "format": "prettier --write \"src/**/*.js\""
    },
    "keywords": [
        "university",
        "management",
        "saas",
        "multi-tenant",
        "education"
    ],
    "author": "UniPilot Team",
    "license": "PROPRIETARY",
    "dependencies": {
        "argon2": "^0.44.0",
        "aws-sdk": "^1.18.0",
        "bcryptjs": "^2.4.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "csv-parser": "^3.2.0",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "express-validator": "^7.0.1",
        "helmet": "^7.1.0",
        "joi": "^17.11.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "nodemailer": "^7.0.13",
        "pdfkit": "^0.13.0",
        "pg": "^8.11.3",
        "pg-hstore": "^2.3.4",
        "razorpay": "^2.9.6",
        "redis": "^4.6.11",
        "sequelize": "^6.35.0",
        "uuid": "^9.0.1",
        "winston": "^3.11.0",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "eslint": "^8.54.0",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-plugin-import": "^2.29.0",
        "jest": "^29.7.0",
        "nodemon": "^3.0.2",
        "prettier": "^3.1.0",
        "sequelize-cli": "^6.6.2",
        "supertest": "^6.3.3"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    }
}
