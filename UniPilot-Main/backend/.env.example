# Environment Configuration
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=unipilot
DB_USER=postgres
DB_PASSWORD=your_password_here

# Database Pool Configuration
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=1h
REFRESH_TOKEN_SECRET=your_refresh_token_secret_change_this
REFRESH_TOKEN_EXPIRY=7d

# Encryption
ENCRYPTION_KEY=your_encryption_key_32_chars_long

# Payment Gateway (Razorpay)
RAZORPAY_MODE=test
RAZORPAY_KEY_ID=your_razorpay_test_key_id
RAZORPAY_KEY_SECRET=your_razorpay_test_key_secret
RAZORPAY_KEY_ID_LIVE=your_razorpay_live_key_id
RAZORPAY_KEY_SECRET_LIVE=your_razorpay_live_key_secret

# AWS Configuration (S3, SES)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=unipilot-files

# Email Configuration
EMAIL_FROM=noreply@unipilot.com
EMAIL_SERVICE=ses # options: ses, smtp

# SMTP Configuration (Alternative to SES)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Biometric Integration
BIOMETRIC_INTEGRATION_ENABLED=false

# University/College Information
UNIVERSITY_NAME=Your University Name
UNIVERSITY_SHORT_NAME=UNIPILOT
UNIVERSITY_CODE=UNI001
UNIVERSITY_ADDRESS=Your University Address
UNIVERSITY_PHONE=+911234567890
UNIVERSITY_EMAIL=info@unipilot.com
UNIVERSITY_WEBSITE=https://unipilot.com
UNIVERSITY_LOGO_PATH=/uploads/logo/logo.png

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=logs/app.log
